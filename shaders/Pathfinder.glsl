mat2 roter(float a) {
    float c = cos(a), s = sin(a);
    return mat2(c, -s, s, c);
}

vec3 trajectoire(float z) {
    return vec3(cos(z * 0.12) * 7.5, sin(z * 0.07) * 4.0, z);
}

float mandel(vec3 p) {
    vec4 q = vec4(p, 1.2);
    vec4 c = q;
    for(int i = 0; i < 9; i++) {
        q.xyz = clamp(q.xyz, -1.0, 1.0) * 2.0 - q.xyz;
        float r2 = dot(q.xyz, q.xyz);
        q *= clamp(max(0.3 / r2, 0.35), 0.0, 3.8);
        q = q * 2.9 / 1.1 + c;
    }
    return length(q.xyz) / q.w;
}

float scene(vec3 p) {
    vec3 guide = trajectoire(p.z);
    vec3 local = p - guide;
    local.xy *= roter(p.z * 0.05 + iTime * 0.1);
    float f = mandel(local * 0.28) * 3.5;
    float tunnel = length(local.xy) - 5.8;
    return max(f, -tunnel);
}

vec3 rendu(vec2 uv, float decalage_temporel) {
    float t = (iTime + decalage_temporel) * 3.2;
    vec3 p = trajectoire(t);
    vec3 cible = trajectoire(t + 2.5);
    
    vec3 dir_z = normalize(cible - p);
    vec3 dir_x = normalize(cross(vec3(0, 1, 0), dir_z));
    vec3 dir_y = cross(dir_z, dir_x);
    
    vec3 rd = normalize(mat3(dir_x, dir_y, dir_z) * vec3(uv, 2.0));
    rd.xy *= roter(iTime * 0.15);

    float d = 0.0, acc = 0.0;
    vec3 col = vec3(0.0);
    
    for(int i = 0; i < 85; i++) {
        vec3 curr = p + rd * d;
        float s = scene(curr);
        if(s < 0.005 || d > 45.0) break;
        
        float lum = 0.018 / (s + 0.035);
        vec3 pal = 0.5 + 0.5 * cos(d * 0.15 + t * 0.1 + vec3(0.0, 1.6, 3.2));
        col += pal * lum * exp(-d * 0.045);
        d += s * 0.75;
    }
    return col;
}

void mainImage(out vec4 O, in vec2 U) {
    vec2 r = iResolution.xy;
    vec2 uv = (U - r * 0.5) / r.y;
    
    vec3 final = vec3(0.0);
    
    float chroma = 0.004 * length(uv);
    final.r = rendu(uv * (1.0 + chroma), 0.0).r;
    final.g = rendu(uv, 0.005).g;
    final.b = rendu(uv * (1.0 - chroma), 0.01).b;
    
    final = pow(final, vec3(1.1));
    final = final / (final + 0.15);
    final = pow(final, vec3(1.0 / 2.2));
    
    float vig = smoothstep(1.5, 0.3, length(uv));
    O = vec4(final * vig, 1.0);
}