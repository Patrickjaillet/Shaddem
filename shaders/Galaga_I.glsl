mat2 rot(float a) {
    float s = sin(a), c = cos(a);
    return mat2(c, -s, s, c);
}

float hachage(vec2 p) {
    p = fract(p * vec2(123.34, 456.21));
    p += dot(p, p + 45.32);
    return fract(p.x * p.y);
}

float bruit(vec2 p) {
    vec2 i = floor(p);
    vec2 f = fract(p);
    f = f * f * (3.0 - 2.0 * f);
    float a = hachage(i);
    float b = hachage(i + vec2(1.0, 0.0));
    float c = hachage(i + vec2(0.0, 1.0));
    float d = hachage(i + vec2(1.0, 1.0));
    return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
}

float sdfVaisseau(vec2 p) {
    p.x = abs(p.x);
    float corps = length(p / vec2(0.8, 1.2)) - 0.03;
    float ailes = length((p - vec2(0.04, -0.01)) / vec2(1.5, 0.5)) - 0.02;
    float react = length(p - vec2(0.015, -0.04)) - 0.015;
    return min(min(corps, ailes), react);
}

void mainImage(out vec4 fCol, in vec2 fCoor) {
    vec2 uv = fCoor / iResolution.y;
    vec2 res = iResolution.xy / iResolution.y;
    float t = iTime;
    
    vec3 col = vec3(0.005, 0.005, 0.01);
    
    float neb = bruit(uv * 1.5 + vec2(t * 0.05, t * 0.1));
    col += vec3(0.05, 0.02, 0.1) * neb;
    
    vec2 pP = vec2(res.x * 0.8, 0.7);
    float dP = length(uv - pP) - 0.3;
    if (dP < 0.0) {
        float texturePlanete = bruit((uv - pP) * 10.0 + t * 0.05);
        col = mix(col, vec3(0.1, 0.15, 0.2) + texturePlanete * 0.05, smoothstep(0.0, -0.01, dP));
        col += vec3(0.2, 0.4, 0.8) * exp(dP * 10.0) * 0.2;
    }

    float eto = hachage(uv + floor(t * 15.0) * 0.001);
    if (eto > 0.995) col += vec3(1.0) * (0.5 + 0.5 * sin(t * 10.0));

    vec2 pJ = vec2(0.5 * res.x + sin(t * 0.5) * 0.4 * res.x, 0.15);
    float velJ = cos(t * 0.5) * 0.2;
    vec2 uvJ = uv - pJ;
    uvJ *= rot(velJ * 4.0);
    float dJ = sdfVaisseau(uvJ);
    
    if (dJ < 0.0) {
        vec3 n = normalize(vec3(dFdx(dJ), dFdy(dJ), 0.02));
        col = mix(vec3(0.1, 0.5, 1.0), vec3(0.8, 0.9, 1.0), uvJ.y + 0.5) * max(n.z, 0.0);
    }
    col += vec3(0.1, 0.5, 1.0) * 0.001 / abs(dJ);

    for(float i = 0.0; i < 5.0; i++) {
        float ph = i * 1.5;
        float cyc = mod(t + ph, 4.0);
        float piq = smoothstep(2.0, 3.5, cyc) * smoothstep(4.0, 3.5, cyc);
        vec2 pE = vec2(0.5 * res.x + sin(t * 0.8 + ph) * 0.6, 0.85 - piq * 0.7);
        vec2 uvE = uv - pE;
        float dE = sdfVaisseau(uvE * rot(3.1415 + piq * sin(t * 10.0)));
        
        float mort = 0.0;
        for(float j = 0.0; j < 3.0; j++) {
            float tB = mod(t + j * 0.6, 1.8);
            vec2 pB = vec2(0.5 * res.x + sin((t - tB) * 0.5) * 0.4 * res.x, 0.15 + tB * 0.8);
            if (distance(pB, pE) < 0.1) mort = 1.0 - smoothstep(0.0, 0.5, mod(tB, 0.5));
        }

        if (mort < 0.1) {
            if (dE < 0.0) col = vec3(1.0, 0.1, 0.1);
            col += vec3(1.0, 0.2, 0.0) * 0.0006 / abs(dE);
        } else {
            col += vec3(1.0, 0.5, 0.2) * (0.02 / max(distance(uv, pE), 0.01)) * mort;
        }
    }

    for(float i = 0.0; i < 3.0; i++) {
        float tB = mod(t + i * 0.6, 1.8);
        vec2 pB = vec2(0.5 * res.x + sin((t - tB) * 0.5) * 0.4 * res.x, 0.15 + tB * 0.8);
        float dB = length(uv - pB) - 0.007;
        if (tB < 1.6) {
            col += vec3(0.0, 1.0, 0.8) * 0.002 / max(dB, 0.001);
            col += vec3(1.0) * exp(-dB * 250.0);
        }
    }

    fCol = vec4(pow(col, vec3(0.8)), 1.0);
}