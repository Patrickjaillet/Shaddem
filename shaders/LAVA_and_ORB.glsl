// LAVA and ORB
// Shadertoy ID: fcSGDR
// Description: LAVA and ORB
// Tags: lava

const vec3 C_NOYAU = vec3(0.05, 0.9, 0.8);
const vec3 C_LUEUR = vec3(0.0, 0.4, 1.0);
const vec3 C_LAVE_C = vec3(4.5, 1.2, 0.2);
const vec3 C_LAVE_B = vec3(1.5, 0.3, 0.05);

float hachage(vec3 p) {
    p = fract(p * 0.3183099 + 0.1);
    p *= 17.0;
    return fract(p.x * p.y * p.z * (p.x + p.y + p.z));
}

float bruit(vec3 x) {
    vec3 i = floor(x);
    vec3 f = fract(x);
    f = f * f * (3.0 - 2.0 * f);
    float n = mix(mix(mix(hachage(i + vec3(0,0,0)), hachage(i + vec3(1,0,0)), f.x),
                   mix(hachage(i + vec3(0,1,0)), hachage(i + vec3(1,1,0)), f.x), f.y),
               mix(mix(hachage(i + vec3(0,0,1)), hachage(i + vec3(1,0,1)), f.x),
                   mix(hachage(i + vec3(0,1,1)), hachage(i + vec3(1,1,1)), f.x), f.y), f.z);
    return n;
}

float mbf(vec3 p, int oct) {
    float v = 0.0;
    float a = 0.5;
    for (int i = 0; i < oct; i++) {
        v += a * bruit(p);
        p *= 2.05;
        a *= 0.5;
    }
    return v;
}

vec2 trajectoire(float t) {
    vec2 p = vec2(sin(t * 0.6), cos(t * 0.27) * 0.4);
    p += vec2(mbf(vec3(t * 2.2, 1.0, 0.0), 2) - 0.5, 
              mbf(vec3(0.0, t * 2.2, 1.0), 2) - 0.5) * 0.24;
    return p;
}

void mainImage(out vec4 fragColor, in vec2 fragCoord) {
    vec2 uv = (fragCoord - 0.5 * iResolution.xy) / iResolution.y;
    float t = iTime;
    
    vec2 pos = trajectoire(t);
    vec3 dir = normalize(vec3(uv, 1.1));
    vec3 cam = vec3(0.0, 0.25, -1.5);
    
    float sol_h = -0.65;
    float d_sol = (sol_h - cam.y) / dir.y;
    vec3 col = vec3(0.01, 0.01, 0.02);
    
    if(d_sol > 0.0 && d_sol < 20.0) {
        vec3 p = cam + d_sol * dir;
        float n = mbf(vec3(p.xz * 1.3, t * 0.1), 4);
        float chaud = pow(n, 2.6);
        
        vec3 lave = mix(vec3(0.01), C_LAVE_B, smoothstep(0.1, 0.45, chaud));
        lave = mix(lave, C_LAVE_C, smoothstep(0.45, 0.85, chaud));
        lave *= (1.2 + 0.4 * sin(t * 2.5 + n * 8.0)) * 2.5;
        
        float eclat = exp(-length(p.xz - pos * 2.2) * 1.8);
        lave += C_LUEUR * eclat * 4.0;
        col = mix(col, lave, exp(-d_sol * 0.18));
    }
    
    float d_noyau = length(uv - pos);
    vec3 feu = C_NOYAU * smoothstep(0.045, 0.0, d_noyau) * 2.5;
    feu += C_LUEUR * pow(0.12 / (d_noyau + 0.12), 2.5) * 2.0;
    
    float etincelles = 0.0;
    for(float i=0.0; i<12.0; i++) {
        float vie = fract((t + hachage(vec3(i, 12.0, 5.0)) * 5.0) * 0.6);
        vec2 p_e = trajectoire(t - vie * 0.5) + (vec2(hachage(vec3(i, 0, 0)), hachage(vec3(0, i, 0))) - 0.5) * 0.4;
        etincelles += smoothstep(0.007, 0.0, length(uv - p_e)) * (1.0 - vie);
    }
    
    vec3 final = col + feu + etincelles * C_NOYAU;
    final = 1.0 - exp(-final * 1.3);
    fragColor = vec4(pow(final, vec3(0.75)), 1.0);
}
