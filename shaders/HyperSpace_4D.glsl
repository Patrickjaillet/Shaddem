mat2 roter(float a) {
    float s = sin(a);
    float c = cos(a);
    return mat2(c, -s, s, c);
}

float distance_monde(vec3 p) {
    vec4 p4 = vec4(p, iTime * 0.2);
    float t1 = iTime * 0.1;
    
    p4.xy *= roter(t1);
    p4.zw *= roter(t1 * 1.2);
    p4.xz *= roter(t1 * 0.8);
    
    vec3 p3 = p4.xyz;
    p3 = abs(mod(p3, 8.0) - 4.0);
    
    float d = 1000.0;
    for(int i = 0; i < 5; i++) {
        p3 = abs(p3) - 1.5;
        p3.xy *= roter(0.5 + float(i) * 0.2);
        p3.yz *= roter(0.4);
        d = min(d, length(p3.yz) - 0.08);
    }
    return d;
}

vec3 calculer_couleur(vec3 ro, vec3 rd) {
    vec3 col_accum = vec3(0.0);
    float t = 0.0;
    for(int i = 0; i < 100; i++) {
        vec3 p = ro + rd * t;
        float d = distance_monde(p);
        float densite = exp(-abs(d) * 9.0);
        
        vec3 col = mix(vec3(0.1, 0.5, 1.0), vec3(1.0, 0.2, 0.6), sin(p.z * 0.1 + iTime) * 0.5 + 0.5);
        col_accum += col * densite * 0.12;
        
        t += max(0.04, abs(d) * 0.5);
        if(t > 35.0) break;
    }
    return col_accum;
}

void mainImage(out vec4 fragColor, in vec2 fragCoord) {
    vec2 uv = (fragCoord - 0.5 * iResolution.xy) / iResolution.y;
    
    float vitese = iTime * 6.0;
    vec3 ro = vec3(0.0, 0.0, vitese);
    
    float rot_x = sin(iTime * 0.2) * 0.3;
    float rot_y = cos(iTime * 0.3) * 0.3;
    
    ro.x += rot_x * 10.0;
    ro.y += rot_y * 10.0;
    
    float decalage = 0.015;
    vec3 final;
    
    final.r = calculer_couleur(ro, normalize(vec3(uv + vec2(decalage, 0.0), 1.2))).r;
    final.g = calculer_couleur(ro, normalize(vec3(uv, 1.2))).g;
    final.b = calculer_couleur(ro, normalize(vec3(uv - vec2(decalage, 0.0), 1.2))).b;
    
    final = pow(final, vec3(0.8));
    final *= 1.2;
    final *= 1.0 - dot(uv, uv) * 0.5;
    
    fragColor = vec4(final, 1.0);
}