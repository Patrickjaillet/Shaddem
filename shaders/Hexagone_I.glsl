// Hexagone I
// Shadertoy ID: sffXRr
// Description: Hexagone
// Tags: hexagone

#define PI 3.14159265359

float aleatoire(vec2 st) {
    return fract(sin(dot(st.xy, vec2(12.9898, 78.233))) * 43758.5453123);
}

float distHexagone(vec2 p) {
    p = abs(p);
    float c = dot(p, normalize(vec2(1, 1.73)));
    c = max(c, p.x);
    return c;
}

void mainImage(out vec4 fragColor, in vec2 fragCoord) {
    vec2 uv = (fragCoord.xy * 2.0 - iResolution.xy) / iResolution.y;
    vec3 couleur = vec3(0.0);
    
    couleur = mix(vec3(0.0, 0.05, 0.2), vec3(0.1, 0.0, 0.2), length(uv));
    
    float angle = atan(uv.y, uv.x);
    float rayon = length(uv);
    float rayons = sin(angle * 12.0 + iTime * 0.5) * 0.5 + 0.5;
    rayons += sin(angle * 20.0 - iTime * 1.0) * 0.3;
    couleur += vec3(0.0, 0.5, 1.0) * rayons * 0.1 * smoothstep(0.0, 1.0, rayon);
    
    vec2 uvHex = uv * 5.0;
    uvHex.y += iTime * 0.5;
    uvHex.x += sin(uvHex.y * 0.5 + iTime) * 0.5;
    
    vec2 gv = fract(uvHex) - 0.5;
    vec2 id = floor(uvHex);
    
    float dist = distHexagone(gv);
    float taille = aleatoire(id) * 0.4;
    float clignotement = sin(iTime * 3.0 + aleatoire(id) * 10.0) * 0.5 + 0.5;
    
    float hex = smoothstep(taille, taille - 0.05, dist);
    
    vec3 couleurP = vec3(0.0);
    float rnd = aleatoire(id + 1.0);
    if (rnd < 0.33) couleurP = vec3(0.0, 1.0, 1.0);
    else if (rnd < 0.66) couleurP = vec3(1.0, 0.0, 1.0);
    else couleurP = vec3(1.0, 1.0, 0.0);
    
    couleur += couleurP * hex * clignotement * 0.6;
    
    couleur *= 1.0 - dot(uv, uv) * 0.6;
    couleur *= 0.9 + 0.1 * sin(fragCoord.y * 0.5 + iTime * 10.0);

    fragColor = vec4(couleur, 1.0);
}
